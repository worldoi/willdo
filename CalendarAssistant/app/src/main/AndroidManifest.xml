<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 超级岛广播权限（signature 级，仅模块自身可用） -->
    <permission
        android:name="com.antgskds.calendarassistant.SEND_ISLAND"
        android:protectionLevel="signature" />
    <uses-permission android:name="com.antgskds.calendarassistant.SEND_ISLAND" />

    <!-- 基础网络与通知 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.POST_PROMOTED_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- 闹钟权限 -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="com.android.alarm.permission.SET_ALARM" />

    <!-- 全屏意图 (闹钟响铃页) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- 前台服务 (胶囊) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- 🔥 新增：开机自启权限 (必须有这个，BootReceiver 才能工作) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 悬浮窗权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Flyme 专用 -->
    <uses-permission android:name="flyme.permission.READ_NOTIFICATION_LIVE_STATE" />

    <!-- 日历同步权限 -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <!-- 短信自动解析取件码 -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CalendarAssistant"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="35">

        <!-- Xposed Module -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:value="Will do 超级岛支持" />
        <meta-data
            android:name="xposedminversion"
            android:value="82" />
        <meta-data
            android:name="xposedscope"
            android:value="com.antgskds.calendarassistant;com.android.systemui" />

        <!-- Flyme 实况通知支持 -->
        <meta-data
            android:name="com.meizu.flyme.live_notification"
            android:value="true" />

        <!-- Samsung 灵动岛支持 -->
        <meta-data
            android:name="com.samsung.android.support.ongoing_activity"
            android:value="true" />

        <!-- UI 入口 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.CalendarAssistant">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 快捷方式中转 Activity (透明、独立任务栈、无动画) -->
        <activity
            android:name=".core.service.shortcut.ShortcutHandleActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:exported="true" />

        <!-- 手动图片选择中转 Activity (悬浮窗用) -->
        <activity
            android:name=".core.service.image.ImagePickHandleActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:exported="false" />

        <!-- 语音随口记录音 Activity：保持真实可见，避免系统把透明页录音判为后台录音 -->
        <activity
            android:name=".core.service.voice.VoiceCaptureHandleActivity"
            android:theme="@style/Theme.CalendarAssistant.VoiceCapture"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:exported="false" />

        <activity
            android:name=".core.service.voice.LocalRecorderTestActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.CalendarAssistant" />

        <activity
            android:name=".widget.ScheduleWidgetConfigureActivity"
            android:exported="true"
            android:theme="@style/Theme.CalendarAssistant" />

        <activity
            android:name=".widget.WeatherWidgetConfigureActivity"
            android:exported="true"
            android:theme="@style/Theme.CalendarAssistant" />

        <activity
            android:name=".widget.CourseWidgetConfigureActivity"
            android:exported="true"
            android:theme="@style/Theme.CalendarAssistant" />

        <!-- 1. 无障碍服务 (截图用) -->
        <service
            android:name=".service.accessibility.TextAccessibilityService"
            android:exported="true"
            android:label="Will do"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>


        <!-- 2. 下拉磁贴服务 -->
        <service
            android:name=".service.tile.CaptureTileService"
            android:icon="@drawable/ic_qs_recognition"
            android:label="识别日程"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- 悬浮窗磁贴服务 -->
        <service
            android:name=".service.tile.FloatingTileService"
            android:icon="@drawable/ic_qs_floating"
            android:label="悬浮窗"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- 4. 悬浮窗服务 -->
        <service
            android:name=".service.floating.FloatingScheduleService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <service
            android:name=".service.clipboard.ClipboardCodeMonitorService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="clipboard_code_monitor" />
        </service>

        <!-- 4. 侧边栏唤起服务 -->
        <service
            android:name=".service.floating.EdgeBarService"
            android:exported="false" />

        <!-- 4. 闹钟广播接收器 -->
        <receiver android:name=".service.receiver.AlarmReceiver" />

        <!-- Store 层日程提醒接收器（含重复日程实例） -->
        <receiver
            android:name=".calendar.receivers.EventReminderReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- 日历定时同步接收器 -->
        <receiver
            android:name=".calendar.receivers.CalDAVSyncReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- 日历内容变更监听 JobService -->
        <service
            android:name=".calendar.jobs.CalDAVUpdateListener"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="true" />

        <!-- 5. 每日汇总接收器 (已修正) -->
        <!-- 这里的 exported=false 是对的，因为我们是用显式 Intent 调用的 -->
        <receiver
            android:name=".service.receiver.DailySummaryReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- 🔥 新增：开机启动接收器 (必须添加) -->
        <!-- exported=true 是必须的，因为要接收系统的 BOOT 广播 -->
        <receiver
            android:name=".service.receiver.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".service.receiver.KeepAliveReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".service.receiver.ReminderReconcileReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".widget.ScheduleWidgetProvider"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.DATE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/schedule_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.WeatherWidgetProvider"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.DATE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/weather_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.CourseWidgetProvider"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.DATE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="com.antgskds.calendarassistant.widget.COURSE_SEGMENT_UP" />
                <action android:name="com.antgskds.calendarassistant.widget.COURSE_SEGMENT_DOWN" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/course_widget_info" />
        </receiver>

        <!-- Shizuku Provider (静默提权核心组件) -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- 事件动作接收器（取件码已取/延长） -->
        <receiver
            android:name=".service.receiver.EventActionReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.antgskds.calendarassistant.action.COMPLETE" />
                <action android:name="com.antgskds.calendarassistant.action.EXTEND" />
            </intent-filter>
        </receiver>

        <!-- 短信自动解析取件码 -->
        <receiver
            android:name=".service.receiver.SmsReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- 系统短信通知监听（用于 MIUI 等 ROM 对 SMS_RECEIVED 的兜底） -->
        <service
            android:name=".service.receiver.SmsNotificationListenerService"
            android:enabled="true"
            android:exported="false"
            android:label="短信通知监听"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>
</manifest>
