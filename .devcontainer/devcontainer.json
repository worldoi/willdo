{
  "name": "Will-do / CalendarAssistant (Android)",
  "image": "mcr.microsoft.com/devcontainers/android:0-17",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-gradle",
        "galudisu.android",
        "JetBrains.kotlin",
        "redhat.java"
      ]
    }
  },
  "remoteEnv": {
    "JAVA_HOME": "/opt/java/openjdk"
  },
  "onCreateCommand": "chmod +x ./start.sh CalendarAssistant/gradlew 2>/dev/null || true",
  "hostRequirements": {
    "cpus": 2,
    "memory": "4gb"
  },
  "forwardPorts": []
}
